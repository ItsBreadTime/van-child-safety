MQTT_HOST=mqtt.example.local
MQTT_PORT=1883
MQTT_USERNAME=mqtt-relay-user
MQTT_PASSWORD=set-a-strong-mqtt-password
MQTT_BASE_TOPIC=bus
MQTT_CLIENT_ID=van-child-safety-relay

DISCORD_BOT_TOKEN=replace-with-bot-token
DISCORD_GLOBAL_CHANNEL_ID=123456789012345678
DISCORD_DEFAULT_CHILD_CHANNEL_ID=123456789012345678
DISCORD_EMERGENCY_CHANNEL_ID=123456789012345678
DISCORD_ALLOWED_MENTION=@everyone
DISTRESS_REPEAT_INTERVAL_S=300

# Optional operator-only slash commands. Commands stay disabled unless the
# guild and at least one user/role allow-list are configured.
# Enables /disarm, /bus_status, and /beacon list|refresh|add|update|active|remove.
DISCORD_COMMAND_GUILD_ID=123456789012345678
DISCORD_OPERATOR_USER_IDS=123456789012345678
# Comma-separated; a user matching either the user or role allow-list is allowed.
DISCORD_OPERATOR_ROLE_IDS=123456789012345678

SCHOOL_ZONE_ENTITY=zone.school
LOG_PATH=/data/van-child-safety-relay.jsonl

# Prometheus metrics + Docker HEALTHCHECK endpoint.
METRICS_PORT=9101
