#pragma once

// Copy this file to main/secrets.h (gitignored) and fill in your real values.
//
// IMPORTANT: use the `#undef` + `#define` pattern below, NOT `#ifndef`. The
// Kconfig defaults are empty strings, but the build system generates
// `#define CONFIG_WIFI_SSID1 ""` into sdkconfig.h regardless. The `#ifndef`
// guard sees that empty define as "already defined" and silently keeps the
// empty value, losing your credentials. `#undef` first, then `#define`, wins.

// WiFi
#undef CONFIG_WIFI_SSID1
#undef CONFIG_WIFI_PASS1
#undef CONFIG_WIFI_SSID2
#undef CONFIG_WIFI_PASS2
#undef CONFIG_WIFI_SSID3
#undef CONFIG_WIFI_PASS3
#undef CONFIG_WIFI_SSID4
#undef CONFIG_WIFI_PASS4
#define CONFIG_WIFI_SSID1    "your-ssid-1"
#define CONFIG_WIFI_PASS1    "your-password-1"
#define CONFIG_WIFI_SSID2    "your-ssid-2"
#define CONFIG_WIFI_PASS2    "your-password-2"
#define CONFIG_WIFI_SSID3    ""
#define CONFIG_WIFI_PASS3    ""
#define CONFIG_WIFI_SSID4    ""
#define CONFIG_WIFI_PASS4    ""

// WireGuard
#undef CONFIG_WG_PRIVATE_KEY
#undef CONFIG_WG_PUBLIC_KEY
#undef CONFIG_WG_PRESHARED_KEY
#define CONFIG_WG_PRIVATE_KEY    "base64-private-key="
#define CONFIG_WG_PUBLIC_KEY     "base64-peer-public-key="
#define CONFIG_WG_PRESHARED_KEY  "base64-preshared-key="
// WG_ENDPOINT / WG_PORT / WG_ADDRESS / WG_ADDRESS_MASK / WG_PERSISTENT_KEEPALIVE
// have non-empty defaults in Kconfig.projbuild; override here only if needed:
// #undef CONFIG_WG_ENDPOINT
// #define CONFIG_WG_ENDPOINT "vpn.example.com"
// #undef CONFIG_WG_PERSISTENT_KEEPALIVE
// #define CONFIG_WG_PERSISTENT_KEEPALIVE 25

// MQTT broker URI (default in Kconfig is mqtt://mqtt.example.local:1883)
#undef CONFIG_MQTT_BROKER_URI
#define CONFIG_MQTT_BROKER_URI "mqtt://mqtt.example.local:1883"
#undef CONFIG_MQTT_USERNAME
#undef CONFIG_MQTT_PASSWORD
#define CONFIG_MQTT_USERNAME     "mqtt-user"
#define CONFIG_MQTT_PASSWORD     "set-a-strong-mqtt-password"

// Discord webhook (LEGACY - disabled by default via ENABLE_LEGACY_DISCORD_WEBHOOK=n).
// Leave empty to keep the relay as the sole Discord notifier.
#undef CONFIG_DISCORD_WEBHOOK_URL
#define CONFIG_DISCORD_WEBHOOK_URL ""

// OTA token (required for the OTA HTTP server to start; fail-closed if empty)
#undef CONFIG_OTA_TOKEN
#define CONFIG_OTA_TOKEN       "set-a-random-ota-token"

// Aliases used throughout the firmware.
#define WIFI_SSID1            CONFIG_WIFI_SSID1
#define WIFI_PASS1            CONFIG_WIFI_PASS1
#define WIFI_SSID2            CONFIG_WIFI_SSID2
#define WIFI_PASS2            CONFIG_WIFI_PASS2
#define WIFI_SSID3            CONFIG_WIFI_SSID3
#define WIFI_PASS3            CONFIG_WIFI_PASS3
#define WIFI_SSID4            CONFIG_WIFI_SSID4
#define WIFI_PASS4            CONFIG_WIFI_PASS4

#define WG_PRIVATE_KEY        CONFIG_WG_PRIVATE_KEY
#define WG_PUBLIC_KEY         CONFIG_WG_PUBLIC_KEY
#define WG_PRESHARED_KEY      CONFIG_WG_PRESHARED_KEY
#define WG_ENDPOINT            CONFIG_WG_ENDPOINT
#define WG_PORT                CONFIG_WG_PORT
#define WG_ADDRESS             CONFIG_WG_ADDRESS
#define WG_ADDRESS_MASK       CONFIG_WG_ADDRESS_MASK
#define WG_PERSISTENT_KEEPALIVE CONFIG_WG_PERSISTENT_KEEPALIVE

#define MQTT_BROKER_URI       CONFIG_MQTT_BROKER_URI
#define MQTT_USERNAME         CONFIG_MQTT_USERNAME
#define MQTT_PASSWORD         CONFIG_MQTT_PASSWORD
#define MQTT_BASE_TOPIC       CONFIG_MQTT_BASE_TOPIC
#define HA_DISCOVERY_PREFIX   CONFIG_HA_DISCOVERY_PREFIX
#define DEVICE_ID             CONFIG_DEVICE_ID
#define DEVICE_NAME           CONFIG_DEVICE_NAME

#define DISCORD_WEBHOOK_URL   CONFIG_DISCORD_WEBHOOK_URL
#define OTA_TOKEN              CONFIG_OTA_TOKEN
